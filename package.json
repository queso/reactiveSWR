{
  "name": "reactive-swr",
  "version": "0.1.0",
  "description": "Meteor-style reactivity for React using SWR and Server-Sent Events",
  "module": "src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "author": "Josh Owens",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/queso/reactiveSWR.git"
  },
  "homepage": "https://github.com/queso/reactiveSWR#readme",
  "bugs": {
    "url": "https://github.com/queso/reactiveSWR/issues"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts src/testing/index.ts src/server/index.ts --outdir dist --target browser --external react --external react-dom --external swr && tsc --project tsconfig.emit.json",
    "prepare": "bun run build",
    "test": "bun test",
    "test:e2e": "bunx playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react-dom": "^19"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "swr": "^2"
  },
  "keywords": [
    "react",
    "swr",
    "sse",
    "server-sent-events",
    "real-time",
    "reactive",
    "meteor"
  ],
  "license": "MIT"
}
